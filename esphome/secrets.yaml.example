# esphome/secrets.yaml.example
#
# Copy this file to esphome/secrets.yaml and fill in your values.
# secrets.yaml is gitignored and must never be committed.
#
# Generate api_encryption_key with:
#   openssl rand -base64 32

wifi_ssid: "your_network_name"
wifi_password: "your_wifi_password"
api_encryption_key: "base64_encoded_32_byte_key_here"
ota_password: "your_ota_password"
